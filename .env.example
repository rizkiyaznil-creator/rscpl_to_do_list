# Database PostgreSQL (connection string).
# - Lokal: gunakan PostgreSQL lokal ATAU buat database gratis di https://neon.tech
#   lalu salin connection string-nya (tidak perlu memasang PostgreSQL sendiri).
# - Produksi (Vercel): gunakan connection string dari Neon.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Kunci rahasia untuk menandatangani JWT sesi login.
# WAJIB diganti dengan nilai acak yang panjang & rahasia.
# Hasilkan nilai acak:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-string-acak-yang-panjang-dan-rahasia"

# --- Email pengingat tugas (opsional; via Gmail) ---
# Buat akun Gmail pengirim, aktifkan Verifikasi 2 Langkah, lalu buat "App Password".
#   SMTP_USER      = alamat Gmail pengirim (mis. notifikasi.rscplusu@gmail.com)
#   SMTP_PASS      = App Password 16 huruf (tanpa spasi)
#   SMTP_FROM_NAME = nama pengirim yang tampil (opsional)
# Bila SMTP_USER/SMTP_PASS kosong, fitur email otomatis dilewati (app tetap jalan).
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="RS CPL USU"

# Rahasia untuk melindungi endpoint cron pengingat (/api/cron/reminders).
# Vercel Cron otomatis mengirim header: Authorization: Bearer <CRON_SECRET>.
CRON_SECRET="ganti-dengan-string-acak"
