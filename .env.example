# Database PostgreSQL (connection string).
# - Lokal: gunakan PostgreSQL lokal ATAU buat database gratis di https://neon.tech
#   lalu salin connection string-nya (tidak perlu memasang PostgreSQL sendiri).
# - Produksi (Vercel): gunakan connection string "Pooled" dari Neon.
# Contoh:
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Kunci rahasia untuk menandatangani JWT sesi login.
# WAJIB diganti dengan nilai acak yang panjang & rahasia.
# Hasilkan nilai acak:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-string-acak-yang-panjang-dan-rahasia"
